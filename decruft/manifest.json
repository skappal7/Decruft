{
  "manifest_version": 3,
  "name": "Decruft",
  "version": "1.0.0",
  "description": "Real-time context staleness monitor and purge tool for Claude. 100% private.",

  "permissions": [
    "storage",
    "activeTab",
    "scripting"
  ],

  "host_permissions": [
    "*://claude.ai/*"
  ],

  "background": {
    "service_worker": "src/background.js",
    "type": "module"
  },

  "content_scripts": [
    {
      "matches": ["*://claude.ai/*"],
      "js": ["src/content.js", "src/purge-bridge.js", "src/widget.js"],
      "run_at": "document_idle"
    }
  ],

  "action": {
    "default_popup": "popup.html",
    "default_title": "Decruft",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },

  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },

  "web_accessible_resources": [
    {
      "resources": [
        "src/widget.css",
        "src/widget.js",
        "src/analyzer.js",
        "src/purge-bridge.js",
        "config/selectors.json"
      ],
      "matches": ["*://claude.ai/*"]
    }
  ]
}
